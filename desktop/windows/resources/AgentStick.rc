#include <windows.h>
#include <winver.h>

#include "resource.h"
#include "version.h"

IDI_AGENTSTICK_APP ICON "app.ico"
IDI_AGENTSTICK_TRAY ICON "tray.ico"

VS_VERSION_INFO VERSIONINFO
FILEVERSION AGENTSTICK_VERSION_RC
PRODUCTVERSION AGENTSTICK_VERSION_RC
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
FILEFLAGS VS_FF_DEBUG
#else
FILEFLAGS 0
#endif
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", AGENTSTICK_COMPANY_NAME
            VALUE "FileDescription", AGENTSTICK_FILE_DESCRIPTION
            VALUE "FileVersion", AGENTSTICK_VERSION_STR
            VALUE "InternalName", "AgentStick"
            VALUE "LegalCopyright", AGENTSTICK_COPYRIGHT
            VALUE "OriginalFilename", "AgentStick.exe"
            VALUE "ProductName", AGENTSTICK_PRODUCT_NAME
            VALUE "ProductVersion", AGENTSTICK_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
